{
  "routes": [
    {
      "route": "/api/export",
      "allowedRoles": ["admin"]
    },
    {
      "route": "/api/register",
      "allowedRoles": ["anonymous", "authenticated"]
    }
  ],
  "responseOverrides": {
    "401": {
      "redirect": "/.auth/login/aad",
      "statusCode": 302
    }
  },
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/*.{css,js,png,jpg,jpeg,svg,ico,webp}"]
  }
}
